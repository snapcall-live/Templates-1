{
    "providerId": "servicepromagic.com",
    "providerName": "ServiceProMagic",
    "serviceId": "website-hosting",
    "serviceName": "ServiceProMagic Website Hosting",
    "version": 1,
    "logoUrl": "https://servicepromagic.com/logo-dm.png",
    "description": "Connect your domain to your ServiceProMagic website. Automatically configures your CNAME and verification records so your site is live in minutes.",
    "variableDescription": "verificationToken: Your ServiceProMagic domain verification token, found in your dashboard under Domain Settings.",
    "syncPubKeyDomain": "servicepromagic.com",
    "syncRedirectDomain": "publishapi-656593342616.us-central1.run.app",
    "records": [
        {
            "groupId": "hosting",
            "type": "CNAME",
            "host": "www",
            "pointsTo": "sites.servicepromagic.com",
            "ttl": 3600
        },
        {
            "groupId": "verification",
            "type": "TXT",
            "host": "@",
            "data": "spm-verify=%verificationToken%",
            "ttl": 3600
        }
    ]
}
