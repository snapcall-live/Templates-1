{
    "providerId": "servicepromagic.com",
    "providerName": "ServiceProMagic",
    "serviceId": "website-hosting",
    "serviceName": "ServiceProMagic Website Hosting",
    "version": 1,
    "logoUrl": "https://servicepromagic.com/logo-dm.png",
    "description": "Connect your domain to your ServiceProMagic website. Configures your A records, CNAME, and domain verification so your site is live in minutes — both yourdomain.com and www.yourdomain.com.",
    "variableDescription": "verificationToken: Your ServiceProMagic domain verification token, found in your dashboard under Domain Settings. Format: servicepromagic-verify-{id}-{hash}",
    "syncPubKeyDomain": "servicepromagic.com",
    "syncRedirectDomain": "publishapi-656593342616.us-central1.run.app",
    "records": [
        {
            "groupId": "hosting",
            "type": "A",
            "host": "@",
            "pointsTo": "104.21.61.176",
            "ttl": 3600
        },
        {
            "groupId": "hosting",
            "type": "A",
            "host": "@",
            "pointsTo": "172.67.212.152",
            "ttl": 3600
        },
        {
            "groupId": "hosting",
            "type": "CNAME",
            "host": "www",
            "pointsTo": "sites.servicepromagic.com",
            "ttl": 3600
        },
        {
            "groupId": "verification",
            "type": "TXT",
            "host": "_servicepromagic",
            "data": "%verificationToken%",
            "ttl": 3600
        }
    ]
}
